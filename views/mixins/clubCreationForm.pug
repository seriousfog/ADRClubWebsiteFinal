mixin clubCreationForm(club, buttonText, saveUrl, cancelUrl, deleteUrl)
    form(action=saveUrl method="POST")
        .club-detail-page
            .club-detail-header
                .club-detail-logo
                    label(for="clublogo")
                    input(type="text" name="clublogo" id="clublogo" placeholder="Club Logo URL" required=true value=club.clublogo)

                .club-detail-info
                    h1
                        label(for="clubname")
                        input(type="text" name="clubname" id="clubname" placeholder="Name of Club" required=true value=club.clubname)
                    .club-detail-tags  -
                        label(for="category")
                        select(name="category" id="category")
                            option(value="") Select Category
                            option(value="Academic" selected=club.category==='Academic') Academic
                            option(value="Arts" selected=club.category==='Arts') Arts
                            option(value="Culture" selected=club.category==='Culture') Culture
                            option(value="Entertainment" selected=club.category==='Entertainment') Entertainment
                            option(value="Health" selected=club.category==='Health') Health
                            option(value="Leadership" selected=club.category==='Leadership') Leadership
                            option(value="Sports" selected=club.category==='Sports') Sports
                            option(value="STEM" selected=club.category==='STEM') STEM
                        | -
                    div.club-detail-description
                        label(for="smalldescription")
                        textarea(name="smalldescription" id="smalldescription" placeholder="Description of Club" rows=5 cols=5 required=true)= club.smalldescription

                    .club-detail-meta
                        div Meets in
                            label(for="meetingdate").form-label
                            input(type="text" name="meetingdate" id="meetingdate" placeholder="e.g., Tuesdays @ Lunch" value=club.meetingdate)
                        div Advisor:
                            label(for="advisorfirstname").form-label
                            input(type="text" name="advisorfirstname" id="advisorfirstname" placeholder="Advisor First Name" value=club.advisorfirstname)
                            label(for="advisorlastname").form-label
                            input(type="text" name="advisorlastname" id="advisorlastname" placeholder="Advisor Last Name" value=club.advisorlastname)
                        div Commitment:
                            label(for="commitment")
                            select(name="commitment" id="commitment")
                                option(value="") Select
                                option(value="Low" selected=club.commitment==='Low') Low
                                option(value="Medium" selected=club.commitment==='Medium') Medium
                                option(value="High" selected=club.commitment==='High') High

                    .club-detail-social
                        img(src='https://upload.wikimedia.org/wikipedia/commons/thumb/9/95/Instagram_logo_2022.svg/1200px-Instagram_logo_2022.svg.png', alt='Instagram')
                        label(for="clubinstagram")
                        input(type="text" name="clubinstagram" id="clubinstagram" placeholder="Instagram Link" value=club.clubinstagram)

            .club-officers-section
                h2 Meet the Officers
                    button.addOfficer(type="button")#addOfficer +
                .club-officers-grid#officerContent
                        //div.club-officer-card#officerContainer
                            div.club-officer-img-form
                                label(for="officerimage") Insert Officer Image
                                input(type="text" name="officerimage" id="officerimage" required=true)
                            p.otitle1
                                label(for="officertitle")
                                    select(name="officertitle" id="officertitle" required=true)
                                        option(value=null)
                                        option(value="president") President
                                        option(value="vice_president") Vice President
                                        option(value="secretary") Secretary
                                        option(value="treasurer") Treasurer
                                        option(value="historian") Historian
                                | :
                                label(for="officerfirstname")
                                input(type="text" name="officerfirstname" id="officerfirstname" placeholder="Officer First Name" required=true)
                                |
                                label(for="officerlastname")
                                input(type="text" name="officerlastname" id="officerlastname" placeholder="Officer Last Name" required=true)

            div.club-engagements
                div.calendar
                    div.calendar-header
                        button(id="prev-month") ‹
                        div#month-year
                        button(id="next-month") ›
                    div.calendar-body
                        div.calendar-weekdays
                            div Sun
                            div Mon
                            div Tue
                            div Wed
                            div Thu
                            div Fri
                            div Sat
                        div.calendar-dates

                div.club-news
                    div.club-news-heading
                        h2 Club News

            .club-info-sections
                .club-info-block
                    h3 What is this Activity?
                    p
                        label(for="bigdescription")
                        textarea(name="bigdescription" id="bigdescription" rows="4" placeholder="Ex: In this [Club/Activity] we...")= club.bigdescription

                .club-info-block
                    h3 What makes this Activity unique?
                    p
                        label(for="uniquedescription")
                        textarea(name="uniquedescription" id="uniquedescription" rows="4" placeholder="Ex: This [Club/Activity] is unique as...")= club.uniquedescription
                .club-info-block
                    h3 What does a typical meeting look like?
                    p= 'Meetings are held ' + (club.meeting || 'at a time TBD') + ' in ' + (club.location || 'a location TBD') + '. Contact the advisor or officers for more details.'


            div.club-bottom
                div.club-map
                    img.map(src="/images/campus_map.png")

            .club-admin-actions
                a.back-btn(href="/") ← Back to All Clubs
                a(href=cancelUrl) Cancel
                button(type="submit") #{buttonText}
                form(action="/clubs/" + club.id + "/delete", method="POST", style="display: inline;")
                    button(type="submit", onclick="return confirm('Are you sure you want to delete this club?')") Delete Club
    if error
        p.error=error